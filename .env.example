# HireWithPrachi Resume Builder — Environment Variables
# Copy this file to .env and fill in your values

# ── Supabase (required) ──────────────────────────────────────
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Razorpay (required for payments) ────────────────────────
VITE_RAZORPAY_KEY_ID=your_razorpay_publishable_key_id

# ── Razorpay Subscription Plan IDs ────────────────────────────
# Create these in Razorpay Dashboard → Products → Plans
# Monthly plan (₹299/month):
VITE_RAZORPAY_PLAN_MONTHLY=plan_XXXXXXXXXX
# Annual plan (₹1,999/year):
VITE_RAZORPAY_PLAN_ANNUAL=plan_YYYYYYYYYY

# ── OpenAI — SERVER-SIDE ONLY ────────────────────────────────
# Do NOT add VITE_OPENAI_API_KEY here. It would be bundled into the
# client JavaScript bundle and exposed publicly.
#
# Instead, set it as a Supabase Secret:
#   npx supabase secrets set OPENAI_API_KEY=sk-proj-...
#
# The parse-resume and enhance-bullet Edge Functions will read it
# from Deno.env.get("OPENAI_API_KEY") securely on the server.

# ── Razorpay — SERVER-SIDE ONLY (Supabase Secrets) ───────────
# Set these via Supabase CLI — never in .env:
#   npx supabase secrets set RAZORPAY_KEY_ID=rzp_live_...
#   npx supabase secrets set RAZORPAY_KEY_SECRET=your_secret_key
#   npx supabase secrets set RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
#
# The create-subscription and razorpay-webhook Edge Functions use these.
